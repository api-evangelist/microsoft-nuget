    {
      "info": {
        "name": "Push a package (PackagePublish)",
        "type": "http"
      },
      "http": {
        "method": "PUT",
        "url": "https://api.nuget.org/v3/package",
        "body": {
          "type": "multipart-form",
          "data": [
            {
              "name": "package",
              "type": "text",
              "value": ""
            }
          ]
        },
        "auth": {
          "type": "apikey",
          "key": "X-NuGet-ApiKey",
          "value": "{{X-NuGet-ApiKey}}",
          "placement": "header"
        }
      },
      "docs": "Push a package (PackagePublish)"
